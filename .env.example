# Host dev: use 127.0.0.1 (not localhost) to avoid IPv6 resolution issues on Windows
# Docker: api container uses postgres host via docker-compose override
DATABASE_URL=postgresql://gym:gym@127.0.0.1:5432/gym_app?schema=public
JWT_ACCESS_SECRET=super-access-secret
JWT_REFRESH_SECRET=super-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
API_PORT=3001
