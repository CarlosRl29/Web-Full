# ===== Railway / Production =====
# DATABASE_URL - Provided by Railway Postgres when linked (do not set manually)
# PORT - Provided by Railway (default 3000)
# JWT_ACCESS_SECRET - Required in prod; generate: openssl rand -base64 32
# JWT_REFRESH_SECRET - Required in prod; generate another strong secret

# ===== Optional (dev/local) =====
# API_PORT=3001  # Only if not using PORT

# ===== AI/RAG (optional, for future features) =====
# OPENAI_API_KEY=
# KNOWLEDGE_PACK_VERSION=dev-v1

# ===== Seed (production: use strong credentials) =====
# SEED_ADMIN_EMAIL=admin@yourdomain.com
# SEED_ADMIN_PASSWORD=YourStrongPassword123!
